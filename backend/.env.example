# Django settings
DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=replace-with-a-random-local-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL (local)
RDS_HOSTNAME=localhost
RDS_PORT=5432
RDS_DB_NAME=duett
RDS_USERNAME=postgres
RDS_PASSWORD=postgres

# Celery / Redis (local)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# AWS placeholders
AWS_REGION=us-east-2
AWS_ACCESS_KEY=replace-me
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_KEY=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_STORAGE_BUCKET_NAME=replace-me
AWS_S3_BUCKET_NAME=replace-me
AWS_S3_BUCKET_NAME_STATIC=replace-me
AWS_S3_CUSTOM_DOMAIN=replace-me
AWS_S3_KEY_PREFIX_STATIC=static
AWS_S3_BUCKET_AUTH=true

# Email placeholders
DUETT_ADMIN_EMAIL=admin@example.com
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_USE_TLS=True
EMAIL_HOST=smtp.mailgun.org
EMAIL_PORT=587
EMAIL_HOST_USER=postmaster@example.com
EMAIL_HOST_PASSWORD=replace-me
MAILGUN_WEBHOOK_KEY=replace-me
DEFAULT_FROM_EMAIL=Duett Notifications <do-not-reply@example.com>

# Twilio placeholders
TWILIO_ACCOUNT_SID=replace-me
TWILIO_AUTH_TOKEN=replace-me
TWILIO_PHONE_NUMBER=+10000000000

# Optional app flags
MAINTENANCE_MODE=False
SEND_EMAIL_CLOSED_TIME=48
SEND_PATIENT_REQUEST_REPORTS=True

# Optional observability
ROLLBAR_ACCESS_TOKEN=
